{
  "experiment": "WineQuality_Red",
  "task_type": "classification",
  "data": {
    "csv_path": "data/wine-quality-red.csv",
    "target_column": "quality",
    "clip_percentile": 0
  },
  "models": [
    {
      "name": "QuantumTransformerVQC",
      "module": "shared_models",
      "vqc_depth": 3,
      "hidden_layers": 2,
      "use_attention": false,
      "_comment": "FFN-only (no attention) ablation"
    },
    {
      "name": "QuantumTransformerVQC",
      "module": "shared_models",
      "vqc_depth": 3,
      "hidden_layers": 2,
      "ffn_mode": "multiple",
      "_comment": "Type 3 (circular-shift) FFN"
    },
    {
      "name": "FullQuantumTransformerVQC",
      "module": "shared_models",
      "vqc_depth": 3,
      "hidden_layers": 2,
      "use_layernorm": true,
      "_comment": "Full QT with LayerNorm"
    },
    {
      "name": "FullQuantumTransformerVQC",
      "module": "shared_models",
      "vqc_depth": 3,
      "hidden_layers": 2,
      "use_attention": false,
      "_comment": "Full QT FFN-only (no quantum attention)"
    },
    {
      "name": "FullQuantumTransformerVQC",
      "module": "shared_models",
      "vqc_depth": 3,
      "hidden_layers": 2,
      "ffn_mode": "multiple",
      "_comment": "Full QT with Type 3 FFN"
    }
  ],
  "training": {
    "lr": 0.005,
    "weight_decay": 0.0,
    "use_scheduler": false,
    "epochs": 5000,
    "print_every": 500,
    "eval_interval": 500
  },
  "batch_size": {
    "train": null,
    "val": null,
    "test": null
  }
}